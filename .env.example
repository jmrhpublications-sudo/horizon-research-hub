# Google Drive API Credentials
# Get these from Google Cloud Console (https://console.cloud.google.com/apis/credentials)

# OAuth Client ID (Desktop Application)
GOOGLE_CLIENT_ID=731274876529-lmvis1vgnh09lf0rcup2igr9gb9pfg55.apps.googleusercontent.com

# OAuth Client Secret (from Google Cloud Console)
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Refresh Token (generate using setup script)
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Root Folder ID (create folder in Google Drive, get ID from URL)
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_root_folder_id